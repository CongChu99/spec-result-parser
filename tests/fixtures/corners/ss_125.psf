// Spectre PSF ASCII
// SS corner 125C — degraded gain, close to MARGIN
HEADER
"PSFversion" "1.1"
"simulator" "spectre"
END HEADER
TYPE
"real" FLOAT DOUBLE PROP(
"units" ""
"scale" "LINEAR"
"grid" 1
)
END TYPE
VALUE
"gain_dc" FLOAT DOUBLE 6.10000e+01 dB
"ugbw" FLOAT DOUBLE 1.05000e+07 Hz
"pm" FLOAT DOUBLE 4.80000e+01 deg
"offset_v" FLOAT DOUBLE 4.00000e-03 V
"cmrr" FLOAT DOUBLE 7.20000e+01 dB
END VALUE
