// Spectre PSF ASCII
HEADER
"PSFversion" "1.1"
"simulator" "spectre"
END HEADER
TYPE
"real" FLOAT DOUBLE PROP(
"units" ""
"scale" "LINEAR"
"grid" 1
)
END TYPE
VALUE
"vref" FLOAT DOUBLE 1.247000e+00 V
"tc_ppm" FLOAT DOUBLE 1.010000e+01 ppm/K
"psrr_dc" FLOAT DOUBLE 6.000000e+01 dB
"startup_time" FLOAT DOUBLE 5.000000e-06 s
END VALUE
